# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
# URL pública a la que redirige el link de confirmación de registro (ej. https://tu-app.vercel.app/login)
VITE_AUTH_EMAIL_REDIRECT_URL=https://your-deployment.vercel.app/login
# Enlace de la sala oficial de Google Meet para el foro privado (opcional)
VITE_FORUM_MEET_URL=https://meet.google.com/xxx-xxxx-xxx

# --- Backend Vercel (sin prefijo VITE_; no exponer al cliente) ---
# Mismo proyecto Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=same_as_VITE_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Mercado Pago (donaciones Checkout Pro — público y área privada)
MERCADOPAGO_ACCESS_TOKEN=APP_USR_..._********
# Secreto en query de notification_url; obligatorio en producción (webhook rechaza sin coincidencia)
MERCADOPAGO_WEBHOOK_SECRET=random_long_string
# URL pública de la app (webhooks y back_urls). Ej. https://tu-app.vercel.app
APP_BASE_URL=https://your-deployment.vercel.app

# Stripe (pagos / auxilios — opcional si solo usas Mercado Pago)
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Opcional; por defecto cop
# STRIPE_CURRENCY=cop

# Gmail SMTP (contraseña de aplicación en Google Account → Seguridad)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=legionbacatainterbogota@gmail.com
SMTP_PASS=app_password_16_chars
EMAIL_FROM="Barra Popular Legión Bacatá Inter Bogotá <legionbacatainterbogota@gmail.com>"

# Twilio SMS (opcional)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+57...

# Job agregaciones (Vercel Cron o llamada manual con este Bearer)
# CRON_SECRET=random_long_string

# Supabase Auth: añadir URL de Vercel en URL Configuration (redirects).
